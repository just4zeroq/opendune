# OpenDune 配置文件
# 复制为 .env 并填写实际值

# 应用配置
APP_NAME=OpenDune
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API服务
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=opendune
KAFKA_GROUP_ID=opendune-group
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# 数据库 - MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=opendune
MYSQL_POOL_SIZE=10

# 数据库 - Doris
DORIS_HOST=localhost
DORIS_PORT=9030
DORIS_USER=root
DORIS_PASSWORD=
DORIS_DATABASE=analytics

# 数据库 - TDengine
TDENGINE_HOST=localhost
TDENGINE_PORT=6030
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=crypto

# 缓存 - Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Alchemy API配置
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_CHAINS=ethereum,polygon,arbitrum,base
ALCHEMY_NETWORKS=mainnet

# BSC节点配置 (Alchemy不支持BSC)
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_BACKUP_RPC_URLS=https://bsc-dataseed1.defibit.io,https://bsc-dataseed1.ninicoin.io

# 交易所API配置
# 币安
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=false

# OKX
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_TESTNET=false

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BYBIT_TESTNET=false

# Bitget
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Flink配置
FLINK_JOB_MANAGER_HOST=localhost
FLINK_JOB_MANAGER_PORT=8081
FLINK_PARALLELISM=4
FLINK_CHECKPOINT_INTERVAL=60000

# 告警配置
ALERT_WEBHOOK_URL=
ALERT_EMAIL_SMTP_HOST=
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=

# 监控
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# 速率限制
RATE_LIMIT_REQUESTS_PER_MINUTE=60
